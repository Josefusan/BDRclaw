# BDRclaw Environment Configuration
# Copy this file to .env and fill in your values.
# Or run: npm run wizard

# ── Core ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
BDR_COMPANY_NAME=Acme Corp
BDR_CLOSER_EMAIL=you@company.com
BDR_WEB_PORT=3000
BDR_WEB_HOST=127.0.0.1
BDR_BRAIN_HOUR=6
ASSISTANT_NAME=BDR
TZ=America/New_York

# ── Gmail (OAuth2 — required for /add-gmail) ──────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Then run: npm run gmail-auth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Gmail sending accounts (up to 3). Run npm run gmail-auth for each.
GMAIL_ACCOUNT_1=you@gmail.com
GMAIL_ACCOUNT_2=
GMAIL_ACCOUNT_3=

# Display name in the email From field (optional — defaults to email username)
GMAIL_SENDER_NAME=Your Name

# Meeting booking link injected by send_meeting_link action
CALENDLY_URL=https://calendly.com/yourname/30min

# Outlook: account.microsoft.com → Security → App passwords
OUTLOOK_ACCOUNT_1_EMAIL=
OUTLOOK_ACCOUNT_1_APP_PASSWORD=

# ── LinkedIn DM Channel ───────────────────────────────────────────────────────
# Run: npm run linkedin-auth  (opens browser so you can log in; saves session cookies)
# Cookies stored in store/linkedin-session.json — never commit this file.
# Keep daily limits low to avoid triggering LinkedIn's automation detection.
LINKEDIN_ENABLED=false
LINKEDIN_ACCOUNT_1_EMAIL=
LINKEDIN_ACCOUNT_1_PASSWORD=
LINKEDIN_ACCOUNT_2_EMAIL=
LINKEDIN_ACCOUNT_2_PASSWORD=
LINKEDIN_DAILY_CONNECTION_LIMIT=20
LINKEDIN_DAILY_DM_LIMIT=50

# ── Twitter / X DM Channel ───────────────────────────────────────────────────
# Requires: developer.twitter.com → Create app → User Auth Settings → OAuth 1.0a
# Basic tier ($100/mo) or higher required for DM API access.
# Run: npm run twitter-auth  (generates the access token/secret for your account)
TWITTER_ENABLED=false
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_DAILY_DM_LIMIT=100

# ── Instagram DM Channel ─────────────────────────────────────────────────────
# Requires: Meta Business Suite → Meta for Developers → Instagram Graph API
# IMPORTANT: Instagram only permits DMs to users who messaged your business first.
# This is a warm-lead follow-up channel, NOT cold outreach (Meta ToS).
# Run: npm run instagram-auth  (guides you through the OAuth flow)
INSTAGRAM_ENABLED=false
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_DAILY_DM_LIMIT=50

# ── CRM ───────────────────────────────────────────────────────────────────────
# Requires /add-hubspot skill to activate
HUBSPOT_API_KEY=

# Requires /add-salesforce skill to activate
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Requires /add-monday skill to activate
MONDAY_API_KEY=

# ── Container ─────────────────────────────────────────────────────────────────
CONTAINER_IMAGE=bdrclaw-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
