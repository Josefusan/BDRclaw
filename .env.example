# BDRclaw Environment Configuration
# Copy this file to .env and fill in your values.
# Or run: npm run wizard

# ── Core ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
BDR_COMPANY_NAME=Acme Corp
BDR_CLOSER_EMAIL=you@company.com
BDR_WEB_PORT=3000
BDR_WEB_HOST=127.0.0.1
# Dashboard auth — REQUIRED on any public deploy. Unset = no login gate (local dev only).
# Sessions are HMAC-signed cookies; rotating either value signs everyone out.
BDR_DASHBOARD_PASSWORD=
BDR_SESSION_SECRET=
# Calendly booking webhook signature verification (recommended once deployed)
CALENDLY_WEBHOOK_SIGNING_KEY=
BDR_BRAIN_HOUR=6
ASSISTANT_NAME=BDR
TZ=America/New_York

# Public base URL of this deployment. Used to build absolute unsubscribe links
# and referenced on the privacy/terms pages. No trailing slash.
BDR_PUBLIC_URL=https://bdrclaw.dev

# ── Legal / CAN-SPAM compliance (REQUIRED before sending commercial email) ─────
# CAN-SPAM (15 U.S.C. §7704) requires every commercial email to carry the
# sender's legal name and a valid physical postal address. These placeholder
# values are safe to commit; replace with your real entity details before send.
BDR_LEGAL_NAME=Acme Corp, Inc.
BDR_MAILING_ADDRESS=123 Example St, Suite 100, San Francisco, CA 94105, USA
# Optional dedicated opt-out mailbox for the List-Unsubscribe mailto: target.
# Falls back to BDR_CLOSER_EMAIL, then unsubscribe@bdrclaw.dev.
BDR_UNSUBSCRIBE_EMAIL=
# Secret used to sign unguessable one-click unsubscribe tokens (HMAC-SHA256).
# Generate one with: openssl rand -hex 32
BDR_UNSUBSCRIBE_SECRET=

# ── Gmail (OAuth2 — required for /add-gmail) ──────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Then run: npm run gmail-auth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Gmail sending accounts (up to 3). Run npm run gmail-auth for each.
GMAIL_ACCOUNT_1=you@gmail.com
GMAIL_ACCOUNT_2=
GMAIL_ACCOUNT_3=

# Display name in the email From field (optional — defaults to email username)
GMAIL_SENDER_NAME=Your Name

# Meeting booking link injected by send_meeting_link action
CALENDLY_URL=https://calendly.com/yourname/30min

# Outlook: account.microsoft.com → Security → App passwords
OUTLOOK_ACCOUNT_1_EMAIL=
OUTLOOK_ACCOUNT_1_APP_PASSWORD=

# ── LinkedIn DM Channel ───────────────────────────────────────────────────────
# Run: npm run linkedin-auth  (opens browser so you can log in; saves session cookies)
# Cookies stored in store/linkedin-session.json — never commit this file.
# Keep daily limits low to avoid triggering LinkedIn's automation detection.
LINKEDIN_ENABLED=false
LINKEDIN_ACCOUNT_1_EMAIL=
LINKEDIN_ACCOUNT_1_PASSWORD=
LINKEDIN_ACCOUNT_2_EMAIL=
LINKEDIN_ACCOUNT_2_PASSWORD=
LINKEDIN_DAILY_CONNECTION_LIMIT=20
LINKEDIN_DAILY_DM_LIMIT=50

# ── Twitter / X DM Channel ───────────────────────────────────────────────────
# Requires: developer.twitter.com → Create app → User Auth Settings → OAuth 1.0a
# Basic tier ($100/mo) or higher required for DM API access.
# Run: npm run twitter-auth  (generates the access token/secret for your account)
TWITTER_ENABLED=false
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_DAILY_DM_LIMIT=100

# ── Instagram DM Channel ─────────────────────────────────────────────────────
# Requires: Meta Business Suite → Meta for Developers → Instagram Graph API
# IMPORTANT: Instagram only permits DMs to users who messaged your business first.
# This is a warm-lead follow-up channel, NOT cold outreach (Meta ToS).
# Run: npm run instagram-auth  (guides you through the OAuth flow)
INSTAGRAM_ENABLED=false
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_DAILY_DM_LIMIT=50

# ── Telegram Bot Channel ─────────────────────────────────────────────────────
# Setup: Message @BotFather on Telegram → /newbot → copy the API token
# No webhook needed — uses long polling (works behind NAT/firewall).
# Get your chat ID: start a conversation with your bot, then call:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=             # Your personal chat ID for admin notifications
TELEGRAM_DAILY_MSG_LIMIT=200

# ── WhatsApp Channel (Twilio) ─────────────────────────────────────────────────
# Setup: twilio.com → Messaging → Sandbox for WhatsApp (dev) or buy a number (prod)
# Webhook URL to set in Twilio Console: https://bdrclaw.dev/webhooks/whatsapp
# Shares TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN with the SMS channel.
TWILIO_WHATSAPP_NUMBER=             # e.g. +14155238886 (Twilio sandbox) or your dedicated number
WHATSAPP_DAILY_MSG_LIMIT=100

# Public origin Twilio uses to reach the /webhooks/* endpoints. Used to
# reconstruct the exact URL for X-Twilio-Signature validation behind a TLS-
# terminating proxy (Railway). No trailing slash. Falls back to the request's
# host + x-forwarded-proto when unset. e.g. https://bdrclaw.dev
WEBHOOK_PUBLIC_URL=https://bdrclaw.dev

# ── SMS Channel (Twilio) ──────────────────────────────────────────────────────
# Setup: twilio.com → Buy a number with SMS capability
# Webhook URL to set in Twilio Console: https://bdrclaw.dev/webhooks/sms
# Respects TCPA (US): never sends more than 2 unsolicited SMS per prospect.
# Inbound webhooks are rejected (403) unless X-Twilio-Signature validates,
# whenever TWILIO_AUTH_TOKEN is set.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=                 # From twilio.com → Account → Settings
TWILIO_AUTH_TOKEN=                  # From twilio.com → Account → Settings
TWILIO_PHONE_NUMBER=                # e.g. +15017122661
SMS_DAILY_MSG_LIMIT=100

# ── CRM ───────────────────────────────────────────────────────────────────────
# Requires /add-hubspot skill to activate
HUBSPOT_API_KEY=

# Requires /add-salesforce skill to activate
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Requires /add-monday skill to activate
MONDAY_API_KEY=

# ── Container ─────────────────────────────────────────────────────────────────
CONTAINER_IMAGE=bdrclaw-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5

# GoHighLevel (LeadConnector) CRM — adapter activates only when BOTH are set
GHL_API_KEY=
GHL_LOCATION_ID=
